# ============================================================
# Nongorr Studio — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values.
# This file is safe to commit — it contains NO secrets.
# ============================================================

# --- Supabase (required) ---
# Project URL from Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co

# Publishable/anon key — safe for browser bundles
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER-ONLY, never in browser code
# ⚠️  Do NOT prefix with VITE_ — that would expose it to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Application (required) ---
# The public URL of this application. Must match the dev server port (8080, set
# in vite.config.ts) so CSRF-origin and OAuth-redirect checks line up locally.
# Local: http://localhost:8080
# Production: https://nongorr.com
VITE_SITE_URL=http://localhost:8080

# --- Node environment ---
# Set automatically by most deployment platforms
NODE_ENV=development

# --- CSRF / trusted origins (optional) ---
# Extra origins trusted for state-changing requests, comma-separated.
# Use ONLY for explicitly-approved preview domains. The canonical VITE_SITE_URL
# is always trusted. Compared as full origin (scheme + host + port).
# ADDITIONAL_ALLOWED_ORIGINS=https://preview.nongorr.com

# --- OAuth provider feature flags (public) ---
# Set to "true" only after the provider is configured in the Supabase
# dashboard (Authentication → Providers). These flags only toggle whether the
# button is OFFERED — the provider client secret lives in Supabase, not here.
VITE_ENABLE_GOOGLE_OAUTH=false
VITE_ENABLE_FACEBOOK_OAUTH=false

# --- Demo commerce (optional, non-production) ---
# Enables the legacy demo order-history / order-tracking views and mock coupons
# in a built (non-dev) preview. `vite dev` already enables demo mode regardless.
# Leave unset/"false" in production: the real checkout uses api.place_order, and
# mock coupons must never resolve in prod (server forces discount = 0). See
# src/lib/checkout-mode.ts.
# VITE_ENABLE_DEMO_CHECKOUT=false

# --- MFA enforcement (server) ---
# Keep "false" until TOTP MFA is enabled in the Supabase dashboard AND at least
# one owner has enrolled, otherwise owners/admins could be locked out. Turn on
# as a go-live step to make owner/admin MFA mandatory.
ENFORCE_ADMIN_MFA=false

# --- Rate limiting (optional, recommended for multi-instance deploys) ---
# When both are set, rate limiting uses a shared Upstash Redis store instead of
# per-instance memory. Get them from https://console.upstash.com (Redis → REST).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Steadfast Courier (Stage 5) ---
# API keys from https://steadfast.com.bd/user/api
# NOTE: the API is served from packzy.com. portal.steadfast.com.bd does NOT
# exist (NXDOMAIN) — do not "correct" the host back to a steadfast.com.bd one.
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
# Webhook: set this FIRST, then enter the SAME value as "Auth Token(Bearer)"
# alongside the Callback Url at https://steadfast.com.bd/user/webhook/add.
# SteadFast sends it back as `Authorization: Bearer <value>`.
# Unset ⇒ /api/webhook/steadfast returns 503 and processes nothing.
STEADFAST_WEBHOOK_SECRET=

# --- Pathao Courier (Stage 5) ---
# Production — client id/secret from https://merchant.pathao.com/courier/developer-api
# Pathao's issue-token API ONLY supports the password grant, so the merchant
# panel login email/password are required too — client id/secret alone cannot
# obtain a token.
PATHAO_BASE_URL=https://api-hermes.pathao.com
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
# Numeric store id from the merchant panel (Get Merchant Store Info → store_id).
# Store ids are issued PER ENVIRONMENT: a production store_id does not exist in
# sandbox. Set PATHAO_SANDBOX_STORE_ID separately — the code never falls back
# from one to the other, because doing so books against a stranger's store.
PATHAO_STORE_ID=
PATHAO_SANDBOX_STORE_ID=
# Webhook: set this FIRST, then enter the SAME value as "Secret" when adding the
# webhook in the merchant panel. Pathao sends it back as `X-PATHAO-Signature`.
# Unset ⇒ /api/webhook/pathao returns 503, and registration will fail.
PATHAO_WEBHOOK_SECRET=
# Sandbox — for testing before going live. Set PATHAO_SANDBOX_ENABLED=true to
# route ALL Pathao traffic to the sandbox host.
PATHAO_SANDBOX_ENABLED=false
PATHAO_SANDBOX_BASE_URL=https://courier-api-sandbox.pathao.com
PATHAO_SANDBOX_CLIENT_ID=
PATHAO_SANDBOX_CLIENT_SECRET=
PATHAO_SANDBOX_USERNAME=
PATHAO_SANDBOX_PASSWORD=

# ── Error monitoring (Stage 7 P3) — optional; inert until set ──
# Server-side (Sentry @sentry/node). Get from Sentry → Project → Client Keys (DSN).
SENTRY_DSN=
# Client-side (Sentry @sentry/react). Usually the same DSN value.
VITE_SENTRY_DSN=

# SEO: allow search engines to index the storefront. Leave unset/false until
# launch on the real custom domain (keeps the temporary vercel.app URL out of
# Google); set to "true" at go-live.
VITE_ALLOW_INDEXING=
