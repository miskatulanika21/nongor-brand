# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
.output
.vinxi
.tanstack/**
.nitro
*.local

# Environment secrets — NEVER commit real env files (only *.example templates)
.env
.env.*
!.env.example
!.env.staging.example

# Test/login credentials — MUST NOT be committed. TEST_CREDENTIALS.md was
# tracked publicly (with LIVE prod accounts) and has been removed; this guard
# stops it (or similar) coming back. Keep such files local-only.
TEST_CREDENTIALS.md
*credentials*.md

# Test / coverage / report artifacts
coverage
playwright-report
test-results
blob-report
# Playwright saved auth/storage state — contains session tokens, never commit
e2e/.auth/

# Wrangler / Cloudflare
.wrangler/
.dev.vars

# Local MCP server config (pins a project ref; do not commit by accident)
.mcp.json

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local agent tooling (machine-specific; skills/config are provisioned per-machine)
.claude/
.codex/

# Local visual-audit render artifacts (regenerated on demand)
docs/.visual-audit-assets/
docs/.visual-audit-render/

# Binary Office reports — keep out of git history (findings live in the .md reports)
*.docx

# Local Supabase config
supabase/config.toml
supabase/.gitignore

.vercel
.env*
!.env.example
!.env.staging.example
