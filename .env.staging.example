# ============================================================
# Nongorr Studio — STAGING environment template
# ============================================================
# Copy to `.env.staging` and fill with your DISPOSABLE staging Supabase project.
# NEVER put the production project's values here. `.env.staging` is gitignored.
#
# Purpose: run destructive/real-order E2E (place order → success → track →
# claim → /orders/:id) and validate candidate migrations (#2/#3/#4) WITHOUT
# ever touching the production database.
# ============================================================

# --- Staging Supabase (a SEPARATE free project, not production) ---
# Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR-STAGING-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# The staging project ref (the subdomain before .supabase.co). The staging
# guard cross-checks this against the linked CLI project so a destructive
# command can never run against production.
STAGING_PROJECT_REF=YOUR-STAGING-REF

# --- App wiring for local E2E against staging ---
VITE_SITE_URL=http://localhost:8080
NODE_ENV=development

# Enable OAuth buttons only if configured on the staging project.
VITE_ENABLE_GOOGLE_OAUTH=false
VITE_ENABLE_FACEBOOK_OAUTH=false

# Keep the REAL checkout (api.place_order) active on staging — do NOT enable the
# demo/mock checkout, or the E2E won't exercise the real order path.
# VITE_ENABLE_DEMO_CHECKOUT=false

# Courier / Sentry / Redis are optional on staging; leave blank to keep them inert.
