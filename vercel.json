{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["bom1"],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "nongor-brand\\.vercel\\.app" }],
      "destination": "https://nongorr.com/$1",
      "permanent": true
    }
  ],
  "images": {
    "sizes": [256, 384, 640, 750, 828, 1080, 1200, 1920],
    "qualities": [50, 75, 80],
    "formats": ["image/avif", "image/webp"],
    "minimumCacheTTL": 2678400,
    "dangerouslyAllowSVG": false,
    "localPatterns": [{ "pathname": "^/assets/.*$", "search": "" }],
    "remotePatterns": [
      {
        "protocol": "https",
        "hostname": "xomjxtmhkglhuiccekld.supabase.co",
        "pathname": "^/storage/v1/object/public/.*$"
      }
    ]
  }
}
